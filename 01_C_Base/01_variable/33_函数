# 函数



```c
#include <stdio.h>

// 函数功能：判断一个数 i 是否是素数
// 返回值：1 表示是素数，0 表示不是素数
int isPrime(int i){
 								// 先默认当前数是素数（标记为1）
 	int ret = 1;
	int k;
								 // 遍历从 2 到 i-1 的所有数，检查是否能整除 i
	for ( k=2; k<i-1; k++ ) {	// 如果 i 能被 k 整除，说明不是素数
	    if ( i%k == 0 ) {		  
	        ret = 0;			// 标记为非素数
	        break;				// 找到因子，直接退出循环，不用再判断
	        }
	    }
	   
	    return ret;		 // 返回判断结果：1=素数，0=非素数
}     
   
int main()
{
    int m,n;			// 存储输入的区间 [m, n]
    int sum = 0;		// 存储区间内所有素数的和
    int cnt = 0;		// 存储区间内素数的个数
    int i;				// 循环变量

    scanf("%d %d", &m, &n);	 // 输入两个整数 m 和 n，表示要判断的区间
    // m=10,n=31;
    if ( m==1 ) m=2;		 	// 特殊处理：1 不是素数，如果 m=1，直接从 2 开始判断
    for ( i=m; i<=n; i++ ) {  	// 遍历区间 [m, n] 中的每一个数
        if ( isPrime(i) ) {		 // 调用 isPrime 函数判断是否是素数
            sum += i;			// 是素数，累加到总和 sum
            cnt++;				// 素数个数 +1
        }
    }
    printf("%d %d\n", cnt, sum);		// 输出：素数的个数 和 素数的总和

    return 0;
}
```

