```c
#include <stdio.h>
// 引入字符串处理头文件，用于字符串操作
#include <string.h>

/**
 * @brief 自定义字符串比较函数（模拟strcmp逻辑）
 * @param s1  待比较字符串1
 * @param s2  待比较字符串2
 * @return    差值：0表示相等，非0表示第一个不同字符的ASCII差值
 */
int mycmp(const char* s1, const char* s2)
{
    // 注释掉的下标遍历写法（等价于下面的指针写法）
    // int idx = 0;
    // while ( s1[idx] == s2[idx] && s1[idx] != '\0' ) { 
    //     idx ++; 
    // }

    // 核心逻辑：指针遍历比较字符串
    // 循环条件：两个指针指向的字符相等 && 未到达字符串末尾（\0是字符串结束符）
    while (*s1 == *s2 && *s1 != '\0') {
        s1++;  // 指针后移，比较下一个字符
        s2++;  // 指针后移，比较下一个字符
    }

    // 返回第一个不同字符的ASCII差值
    // 若字符串相等，此时*s1和*s2都是\0，差值为0
    return *s1 - *s2;
}

int main(int argc, char const *argv[])
{
    // 定义并初始化两个字符数组（字符串）
    char s1[] = "abc";
    char s2[] = "abc";

    // 调用自定义比较函数，打印两个字符串的比较结果
    printf("%d\n", mycmp(s1,s2));
    // 直接打印字符 'a' 与 'A' 的ASCII差值
    // 'a' ASCII值：97；'A' ASCII值：65；差值为 32
    printf("%d\n", 'a'-'A');

    return 0;
}
```

