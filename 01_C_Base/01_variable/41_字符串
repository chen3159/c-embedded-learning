```c
#include <stdio.h>  // 引入标准输入输出头文件，用于使用 scanf 和 

int main(void)      // 主函数，程序的入口点
{
    // 定义两个字符数组（字符串），每个数组长度为 8
    // 注意：这意味着每个字符串最多只能存储 7 个字符，因为需要留 1 个字节给字符串结束符 '\0'
    char word[8];
    char word2[8];

    // 从键盘读取第一个字符串并存储到 word 数组中
    // 注意：如果输入的字符串超过 7 个字符，会导致缓冲区溢出（Buffer Overflow），这是不安全的
    scanf("%s", word);

    // 从键盘读取第二个字符串并存储到 word2 数组中
    scanf("%s", word2);

    // 按照指定格式输出两个字符串
    // 输出格式为：第一个字符串 + "###" + 第二个字符串 + "##" + 换行符
    printf("%s###%s##\n", word, word2);

    return 0;       // 程序正常结束，返回 0
}
```

