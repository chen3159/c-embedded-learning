### Strlen

![image-20260407204449161](https://raw.githubusercontent.com/czh010/images/main/hardwa/image-20260407204449161.png)

```c
#include <stdio.h>   
#include <string.h>  

// 自定义函数：模拟strlen，计算字符串有效长度（不含'\0'）
// 参数：const char* s 表示传入的字符串只读，防止意外修改
size_t mylen(const char* s)
{
    int cnt = 0;   // 计数器，用来记录字符个数
    int idx = 0;   // 数组下标，用来遍历字符串

    // 循环条件：当s[idx]不是字符串结束符'\0'时，继续循环
    while (s[idx] != '\0') {
        idx++;    // 下标往后移一位
        cnt++;    // 有效字符计数+1
    }

    return cnt;    // 返回有效字符的个数
}

int main(int argc, char const *argv[])
{
    // 定义字符数组，用字符串常量初始化，末尾会自动加上'\0'
    char line[] = "Hello";

    // 调用自定义的mylen函数，打印字符串有效长度
    // %lu 是无符号长整型的格式化输出符，因为size_t本质是unsigned long
    printf("strlen=%lu\n", mylen(line));

    // 打印数组的实际占用空间大小（包含'\0'）
    printf("sizeof=%lu\n", sizeof(line));

    return 0;   // 程序正常结束，返回0给操作系统
}
```

