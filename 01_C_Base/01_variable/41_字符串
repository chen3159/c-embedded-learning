### Strcmp

![image-20260407205640015](https://raw.githubusercontent.com/czh010/images/main/hardwa/image-20260407205640015.png)



```c
#include <stdio.h>

#include <string.h>

int main(int argc, char const *argv[])
{
    // 定义字符数组s1，存储字符串"abc"，系统自动在末尾添加结束符'\0'
    char s1[] = "abc";
    // 定义字符数组s2，存储字符串"abc"
    char s2[] = "abc";

    // 调用strcmp函数比较两个字符串，结果用printf打印
    // strcmp相等返回0，s1>s2返回正数，s1<s2返回负数
    printf("%d\n", strcmp(s1,s2));

    // 计算小写字母a和大写字母A的ASCII码差值并打印
    // 小写字母的ASCII码比对应大写字母大32
    printf("%d\n", 'a'-'A');

    // 程序正常结束，返回0
    return 0;
}
```

